---
import Icon from './Icon.astro';
import { site } from '../data/site';
---
<!-- סרגל חיוג/וואטסאפ צף - מובייל בלבד -->
<div class="fcta" aria-label="פעולות מהירות">
  <a class="fcta__btn fcta__btn--call" href={`tel:${site.phoneRaw}`}><Icon name="phone" size={20} /> חייגו עכשיו</a>
  <a class="fcta__btn fcta__btn--wa" href={`https://wa.me/${site.whatsapp}`} target="_blank" rel="noopener"><Icon name="whatsapp" size={20} /> וואטסאפ</a>
</div>

<style>
  .fcta { display: none; }
  @media (max-width: 980px) {
    .fcta {
      display: grid; grid-template-columns: 1fr 1fr; gap: 0;
      position: fixed; inset-inline: 0; bottom: 0; z-index: 90;
      box-shadow: 0 -4px 16px rgba(10,37,64,.15);
    }
    .fcta__btn { display: flex; align-items: center; justify-content: center; gap: .5rem; padding: .95rem; color: #fff; font-weight: 700; font-size: var(--fs-base); }
    .fcta__btn--call { background: var(--c-navy); }
    .fcta__btn--wa { background: var(--c-cta); }
    body { padding-bottom: 60px; }
  }
</style>
