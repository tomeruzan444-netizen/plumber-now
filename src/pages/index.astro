---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FloatingCTA from '../components/FloatingCTA.astro';
import LeadForm from '../components/LeadForm.astro';
import Icon from '../components/Icon.astro';
import { site, services, regions, trustPoints } from '../data/site';

const allRegions = [regions.center, regions.north, regions.south];
const steps = [
  { icon: 'send', title: 'משאירים פרטים', desc: 'ממלאים טופס קצר או מתקשרים - לוקח פחות מדקה' },
  { icon: 'phone', title: 'מקבלים שיחה', desc: 'אינסטלטור מקצועי באזורכם חוזר אליכם במהירות' },
  { icon: 'banknote', title: 'מחיר שקוף', desc: 'מקבלים הצעת מחיר ברורה לפי המחירון מראש' },
  { icon: 'check-circle', title: 'העבודה מבוצעת', desc: 'שירות מהיר ואמין עד הבית, באחריות מלאה' },
];

const jsonLd = [{
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: site.name,
  description: 'מובילים בשירותי אינסטלציה - כל עבודות האינסטלציה במקום אחד עם מחירונים',
  url: site.url,
  telephone: site.phone,
  email: site.email,
  areaServed: 'IL',
  image: `${site.url}/images/logo.png`,
}];
---
<BaseLayout
  title="אינסטלטור עכשיו | כל עבודות האינסטלציה במקום אחד עם מחירונים"
  description="מחפשים אינסטלטור עכשיו? הגעתם למקום הנכון. אנחנו עושים את כל עבודות האינסטלציה עכשיו! במחיר מעולה. הציצו במחירונים המקיפים שלנו"
  jsonLd={jsonLd}
>
  <Header slot="header" />
  <Footer slot="footer" />
  <FloatingCTA slot="floating" />

  <!-- ===== HERO ===== -->
  <section class="hero">
    <div class="container hero__grid">
      <div class="hero__copy">
        <p class="hero__eyebrow"><Icon name="zap" size={16} /> שירות בכל הארץ · זמינות מהירה</p>
        <h1>אינסטלטור מקצועי<br />מגיע אליכם <span class="hl">עכשיו</span></h1>
        <p class="hero__lead">כל עבודות האינסטלציה במקום אחד - פתיחת סתימות, איתור נזילות, החלפת ברזים ועוד. עם מחירונים שקופים ושירות אמין שמגיע עד הבית.</p>
        <div class="hero__cta">
          <a class="btn btn--cta btn--lg" href={`tel:${site.phoneRaw}`}><Icon name="phone" size={20} /> {site.phone}</a>
          <a class="btn btn--ghost btn--lg" href="/פתיחת-סתימות/">לשירותים שלנו <Icon name="arrow-left" size={18} /></a>
        </div>
        <ul class="hero__chips">
          <li><Icon name="check" size={16} /> ללא התחייבות</li>
          <li><Icon name="check" size={16} /> מחיר מראש</li>
          <li><Icon name="check" size={16} /> אחריות מלאה</li>
        </ul>
      </div>
      <div class="hero__form">
        <LeadForm />
      </div>
    </div>
  </section>

  <!-- ===== TRUST STRIP ===== -->
  <section class="trust">
    <div class="container trust__grid">
      {trustPoints.map((t) => (
        <div class="trust__item">
          <span class="trust__ic"><Icon name={t.icon} size={26} /></span>
          <div><strong>{t.title}</strong><span>{t.desc}</span></div>
        </div>
      ))}
    </div>
  </section>

  <!-- ===== SERVICES ===== -->
  <section class="section container">
    <header class="sec-head">
      <p class="eyebrow">השירותים שלנו</p>
      <h2>כל שירותי האינסטלציה תחת קורת גג אחת</h2>
      <p class="sec-sub">בחרו את השירות הדרוש לכם וקבלו מידע מלא, טיפים מקצועיים ומחירון מפורט</p>
    </header>
    <div class="cards-grid">
      {services.map((s) => (
        <a class="svc-card" href={s.href}>
          <span class="svc-card__ic"><Icon name={s.icon} size={28} /></span>
          <h3>{s.label}</h3>
          <p>{s.desc}</p>
          <span class="svc-card__more">למידע ומחירון <Icon name="arrow-left" size={16} /></span>
        </a>
      ))}
    </div>
  </section>

  <!-- ===== HOW IT WORKS ===== -->
  <section class="section section--soft">
    <div class="container">
      <header class="sec-head">
        <p class="eyebrow">פשוט ומהיר</p>
        <h2>איך זה עובד?</h2>
        <p class="sec-sub">4 צעדים קלים מהבעיה ועד הפתרון</p>
      </header>
      <ol class="steps">
        {steps.map((s, i) => (
          <li class="step">
            <span class="step__num">{i + 1}</span>
            <span class="step__ic"><Icon name={s.icon} size={26} /></span>
            <h3>{s.title}</h3>
            <p>{s.desc}</p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- ===== SERVICE AREAS ===== -->
  <section class="section container">
    <header class="sec-head">
      <p class="eyebrow">פריסה ארצית</p>
      <h2>אינסטלטור בכל אזור בארץ</h2>
      <p class="sec-sub">בחרו את העיר שלכם וקבלו אינסטלטור מקומי מהר</p>
    </header>
    <div class="areas-grid">
      {allRegions.map((r) => (
        <div class="area-card">
          <h3><Icon name="map-pin" size={20} /> <a href={r.href}>אינסטלטור ב{r.label}</a></h3>
          <ul>{r.cities.map((c) => <li><a href={c.href}><Icon name="chevron-left" size={15} />{c.label}</a></li>)}</ul>
        </div>
      ))}
    </div>
  </section>

  <!-- ===== FINAL CTA ===== -->
  <section class="cta-band">
    <div class="container cta-band__row">
      <div>
        <h2>צריכים אינסטלטור עכשיו?</h2>
        <p>אנחנו זמינים בשבילכם - חייגו ותקבלו שירות מהיר ומקצועי עוד היום.</p>
      </div>
      <a class="btn btn--lg cta-band__btn" href={`tel:${site.phoneRaw}`}><Icon name="phone" size={20} /> {site.phone}</a>
    </div>
  </section>
</BaseLayout>

<style>
  /* HERO */
  .hero { background: linear-gradient(160deg, var(--c-brand-50) 0%, #fff 60%); padding-block: clamp(2rem, 5vw, 4rem); position: relative; }
  .hero__grid { display: grid; grid-template-columns: 1.1fr .9fr; gap: clamp(1.5rem, 4vw, 3.5rem); align-items: center; }
  .hero__eyebrow { display: inline-flex; align-items: center; gap: .4rem; background: #fff; border: 1px solid var(--c-line); color: var(--c-brand-600); font-weight: 700; font-size: var(--fs-sm); padding: .4rem .9rem; border-radius: 999px; box-shadow: var(--shadow-sm); }
  .hero h1 { font-size: clamp(2rem, 5vw, 3.4rem); margin: 1rem 0; }
  .hero h1 .hl { color: var(--c-brand); }
  .hero__lead { font-size: var(--fs-lg); color: var(--c-body); max-width: 46ch; }
  .hero__cta { display: flex; gap: .8rem; flex-wrap: wrap; margin: 1.6rem 0 1.2rem; }
  .hero__chips { display: flex; gap: 1.2rem; flex-wrap: wrap; list-style: none; padding: 0; margin: 0; }
  .hero__chips li { display: inline-flex; align-items: center; gap: .35rem; color: var(--c-navy); font-weight: 600; font-size: var(--fs-sm); }
  .hero__chips svg { color: var(--c-cta); }

  /* TRUST */
  .trust { background: var(--c-navy); }
  .trust__grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.5rem; padding-block: 1.8rem; }
  .trust__item { display: flex; align-items: center; gap: .9rem; color: #fff; }
  .trust__ic { display: grid; place-items: center; width: 52px; height: 52px; border-radius: 12px; background: rgba(255,255,255,.1); color: var(--c-brand); flex-shrink: 0; }
  .trust__item strong { display: block; font-size: var(--fs-base); color: #fff; }
  .trust__item span { display: block; color: #94a3b8; font-size: var(--fs-sm); }

  /* SECTION HEADERS */
  .sec-head { text-align: center; max-width: 640px; margin: 0 auto clamp(1.5rem, 4vw, 2.5rem); }
  .sec-sub { color: var(--c-muted); font-size: var(--fs-lg); margin-top: .5rem; }

  /* SERVICE CARDS */
  .cards-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.2rem; }
  .svc-card { background: #fff; border: 1px solid var(--c-line); border-radius: var(--radius); padding: 1.5rem; box-shadow: var(--shadow-sm); transition: transform .15s, box-shadow .15s, border-color .15s; display: flex; flex-direction: column; }
  .svc-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-lg); border-color: var(--c-brand); }
  .svc-card__ic { display: grid; place-items: center; width: 56px; height: 56px; border-radius: 14px; background: var(--c-brand-50); color: var(--c-brand-600); margin-bottom: 1rem; }
  .svc-card h3 { font-size: var(--fs-lg); margin-bottom: .35rem; }
  .svc-card p { font-size: var(--fs-sm); color: var(--c-muted); flex-grow: 1; }
  .svc-card__more { display: inline-flex; align-items: center; gap: .35rem; color: var(--c-brand-600); font-weight: 700; font-size: var(--fs-sm); margin-top: .8rem; }

  /* STEPS */
  .steps { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.2rem; list-style: none; padding: 0; margin: 0; counter-reset: step; }
  .step { background: #fff; border: 1px solid var(--c-line); border-radius: var(--radius); padding: 2rem 1.3rem 1.4rem; text-align: center; position: relative; box-shadow: var(--shadow-sm); }
  .step__num { position: absolute; top: -18px; inset-inline-start: 50%; transform: translateX(50%); width: 38px; height: 38px; display: grid; place-items: center; background: var(--c-navy); color: #fff; border-radius: 50%; font-weight: 800; }
  .step__ic { display: inline-grid; place-items: center; width: 60px; height: 60px; border-radius: 16px; background: var(--c-brand-50); color: var(--c-brand-600); margin-bottom: .9rem; }
  .step h3 { font-size: var(--fs-lg); margin-bottom: .3rem; }
  .step p { font-size: var(--fs-sm); color: var(--c-muted); margin: 0; }

  /* AREAS */
  .areas-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.2rem; }
  .area-card { background: #fff; border: 1px solid var(--c-line); border-radius: var(--radius); padding: 1.5rem; box-shadow: var(--shadow-sm); }
  .area-card h3 { display: flex; align-items: center; gap: .5rem; font-size: var(--fs-lg); margin-bottom: 1rem; padding-bottom: .8rem; border-bottom: 2px solid var(--c-brand-50); }
  .area-card h3 svg { color: var(--c-brand); }
  .area-card ul { list-style: none; padding: 0; margin: 0; display: grid; grid-template-columns: 1fr 1fr; gap: .5rem; }
  .area-card li a { display: inline-flex; align-items: center; gap: .25rem; color: var(--c-body); font-size: var(--fs-sm); }
  .area-card li a:hover { color: var(--c-brand-600); }
  .area-card li svg { color: var(--c-brand); }

  /* CTA BAND */
  .cta-band { background: linear-gradient(120deg, var(--c-brand) 0%, var(--c-brand-600) 100%); color: #fff; }
  .cta-band__row { display: flex; align-items: center; justify-content: space-between; gap: 1.5rem; padding-block: 2.5rem; flex-wrap: wrap; }
  .cta-band h2 { color: #fff; }
  .cta-band p { color: rgba(255,255,255,.9); margin: .4rem 0 0; font-size: var(--fs-lg); }
  .cta-band__btn { background: #fff; color: var(--c-brand-600); }
  .cta-band__btn:hover { background: var(--c-navy); color: #fff; }

  /* RESPONSIVE */
  @media (max-width: 980px) {
    .hero__grid { grid-template-columns: 1fr; }
    .hero__form { order: -1; }
    .trust__grid { grid-template-columns: 1fr 1fr; }
    .cards-grid { grid-template-columns: 1fr 1fr; }
    .steps { grid-template-columns: 1fr 1fr; }
    .areas-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 560px) {
    .cards-grid, .trust__grid, .steps { grid-template-columns: 1fr; }
    .area-card ul { grid-template-columns: 1fr; }
  }
</style>
